# Google Gemini API Key (Required for AI summaries and stats generation)
# Get a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Resend API Key (Optional, for email notifications)
# Get a free key from Resend: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=your_email@domain.com

# Database Configuration (Optional, falls back to SQLite scoresnap.db if unset)
# Neon PostgreSQL URL for production: postgres://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host.neon.tech/scoresnap?sslmode=require

# JWT Token Signing Secret (Required for security)
# Generate a secure string using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=some_long_random_hex_string_here

# SMTP Email Fallback Configuration (Optional, if you prefer not to use Resend)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Enable Background Tasks inside the FastAPI process (set to False in production if using cron endpoints)
RUN_SCHEDULER_IN_APP=True
